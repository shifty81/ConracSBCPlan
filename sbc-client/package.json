{
  "name": "sbc-client",
  "version": "1.0.0",
  "description": "Edge software for LattePanda 3 Delta 864 SBC at fueling islands — NEXUS Facility Operations Platform",
  "main": "main.js",
  "scripts": {
    "start": "node main.js",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "node-fetch": "^2.7.0",
    "serialport": "^12.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testMatch": ["<rootDir>/tests/**/*.test.js"],
    "moduleNameMapper": {
      "^../../shared/constants$": "<rootDir>/../shared/constants",
      "^../../shared/logging$": "<rootDir>/../shared/logging",
      "^../../shared/utils$": "<rootDir>/../shared/utils",
      "^../../shared/schemas$": "<rootDir>/../shared/schemas"
    }
  }
}

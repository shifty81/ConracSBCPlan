# ============================================
# NEXUS Facility Operations Platform - Environment Variables
# ============================================
# Copy this file to .env and configure for your site.

# --- Server Configuration ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
NODE_ENV=production

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexus
DB_USER=nexus_admin
DB_PASSWORD=changeme

# --- Authentication ---
JWT_SECRET=changeme
JWT_EXPIRY=3600
SESSION_TIMEOUT=1800

# --- Site Configuration ---
SITE_ID=NKY-CVG
SITE_NAME=NKY / CVG ConRAC

# --- SBC Communication ---
SBC_HEARTBEAT_INTERVAL=30
SBC_TRANSACTION_PUSH_DELAY=10
SBC_OFFLINE_BUFFER_SIZE=10000

# --- Tank Monitoring ---
TANK_POLL_INTERVAL=300
TANK_ALERT_LOW_PERCENT=20
TANK_ALERT_HIGH_PERCENT=95

# --- Car Wash Monitoring ---
CARWASH_CYCLE_TIMEOUT=600
CARWASH_ALERT_WATER_GALLONS=100
CARWASH_ALERT_CHEMICAL_GALLONS=5

# --- Backup & Maintenance ---
NIGHTLY_MAINTENANCE_TIME=03:00
BACKUP_RETENTION_DAYS=30
ARCHIVE_RETENTION_YEARS=5
CLOUD_BACKUP_ENABLED=false
CLOUD_BACKUP_ENDPOINT=

# --- Forms & Inspections ---
NEXUS_FORMS_WEBHOOK_SECRET=changeme
NEXUS_FORMS_SYNC_INTERVAL=300

# --- Vendor Management ---
VENDOR_SERVICE_PORT=3006
VENDOR_INSURANCE_WARNING_DAYS=30

# --- Logging ---
LOG_LEVEL=info
LOG_DIR=/var/log/nexus

# --- TLS / Security ---
TLS_CERT_PATH=/etc/ssl/certs/nexus.crt
TLS_KEY_PATH=/etc/ssl/private/nexus.key
